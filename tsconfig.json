{
  "compilerOptions": {
    "target": "es2023",//changed
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "ignoreDeprecations": "5.0", // added
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
     "@/*": ["./src/*"] ,// changed
     "@ui/": ["./src/components/ui/"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",  //added
    "src/**/*.tsx",  //added
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
